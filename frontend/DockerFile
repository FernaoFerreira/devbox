# =============================================
# Dockerfile - Frontend (React + Vite)
# =============================================

# Usa a imagem oficial do Node.js versão LTS com Alpine Linux
# Alpine é uma distro minimalista, gerando imagens menores
FROM node:lts-alpine

# Define o diretório de trabalho dentro do container
# Todos os comandos seguintes serão executados neste diretório
WORKDIR /app

# Copia apenas os arquivos de dependências primeiro
# Isso aproveita o cache do Docker: se package.json não mudar,
# o npm install não será reexecutado em builds futuros
COPY package*.json ./

# Instala as dependências do projeto
RUN npm install

# Copia o restante dos arquivos do projeto
# Em desenvolvimento, o volume no docker-compose.yml
# sobrescreve esses arquivos com os locais (hot-reload)
COPY . .

# Expõe a porta que o Vite usa por padrão
EXPOSE 5173

# Comando para iniciar o servidor de desenvolvimento do Vite
# --host 0.0.0.0 é essencial: faz o Vite escutar em todas as interfaces,
# não apenas localhost, permitindo acesso de fora do container
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]