# ==============================================
# VARIÁVEIS DE AMBIENTE - LAB02
# Copie este arquivo para .env e ajuste os valores
# ==============================================

# --- PORTAS DO HOST ---
# Porta onde o Nginx (proxy reverso) ficará acessível
NGINX_PORT=80

# Porta onde o pgAdmin ficará acessível
PGADMIN_PORT=5050

# --- BANCO DE DADOS (PostgreSQL) ---
POSTGRES_USER=devuser
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=devdb

# --- PGADMIN ---
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=adminpassword

# --- PORTAS INTERNAS (usadas dentro da rede Docker) ---
FRONTEND_PORT=5173
BACKEND_PORT=3000
